{
  "name": "Editor Markdown",
  "short_name": "MDEditor",
  "description": "Um editor Markdown profissional e moderno com integração nativa de ficheiros.",
  "start_url": "./",
  "display": "standalone",
  "theme_color": "#ffffff",
  "background_color": "#ffffff",
  "icons": [
    {
      "src": "https://cdn-icons-png.flaticon.com/512/2088/2088832.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "file_handlers": [
    {
      "action": "./",
      "accept": {
        "text/markdown": [
          ".md",
          ".markdown"
        ],
        "text/plain": [
          ".txt"
        ]
      }
    }
  ]
}
